# Never expose this key through an EXPO_PUBLIC_ variable.
OPENAI_API_KEY=

# The API base URL visible to the app. Use your computer's LAN IP for a phone.
EXPO_PUBLIC_API_BASE_URL=http://localhost:8787

# Optional server settings.
PORT=8787
APP_ORIGIN=http://localhost:8081
SAFETY_ID_SALT=replace-this-outside-local-development

# Explicit defaults: Realtime handles audio/barge-in; Sol handles coaching.
OPENAI_REALTIME_MODEL=gpt-realtime-2.1
OPENAI_COACH_MODEL=gpt-5.6-sol
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
